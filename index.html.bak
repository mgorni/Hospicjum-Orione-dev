<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Hospicjum domowe – Apostolstwo Miłosierdzia</title>
  <link rel="stylesheet" href="/assets/css/style.css" />
</head>

<body>

  <div class="page-bg" aria-hidden="true"></div>

  <header class="site-header">
    <nav class="topnav topnav-bar" aria-label="Główne menu">
      <ul class="topnav-menu">
        <li class="topnav-item topnav-item-has-submenu">
          <button
            type="button"
            class="navlink navbutton"
            aria-expanded="false"
            aria-haspopup="true"
          >
            Szukam wsparcia
          </button>
          <ul class="submenu" aria-label="Szukam wsparcia">
            <li><a href="#o-nas" data-page="o-nas" class="navlink submenu-link">jako Pacjent</a></li>
            <li><a href="#jak-pomagac" data-page="jak-pomagac" class="navlink submenu-link">jako Członek Rodziny</a></li>
          </ul>
        </li>

        <li class="topnav-item topnav-item-has-submenu topnav-item-center">
          <button
            type="button"
            class="navlink navbutton"
            aria-expanded="false"
            aria-haspopup="true"
          >
            hospicjum
          </button>
          <ul class="submenu" aria-label="Hospicjum">
            <li><a href="#o-patronie" data-page="o-patronie" class="navlink submenu-link">O patronie</a></li>
            <li><a href="#o-nas" data-page="o-nas" class="navlink submenu-link">O nas</a></li>
            <li><a href="#aktualnosci" data-page="aktualnosci" class="navlink submenu-link">Aktualności</a></li>
            <li><a href="#kontakt" data-page="kontakt" class="navlink submenu-link">Kontakt</a></li>
          </ul>
        </li>

        <li class="topnav-item topnav-item-has-submenu">
          <button
            type="button"
            class="navlink navbutton"
            aria-expanded="false"
            aria-haspopup="true"
          >
            Chcę wesprzeć
          </button>
          <ul class="submenu" aria-label="Chcę wesprzeć">
            <li><a href="#o-nas" data-page="o-nas" class="navlink submenu-link">jako Wolontariusz</a></li>
            <li><a href="#wplaty" data-page="wplaty" class="navlink submenu-link">jako Darczyńca</a></li>
            <li><a href="#o-nas" data-page="o-nas" class="navlink submenu-link">jako Specjalista</a></li>
          </ul>
        </li>

        <li class="topnav-item topnav-item-cta">
          <a href="#wplaty" data-page="wplaty" class="navlink navlink-cta">Wesprzyj teraz</a>
        </li>
      </ul>
    </nav>
  </header>

  <main id="content" class="content" aria-live="polite">
    <div class="loading">Ładowanie…</div>
  </main>

  <footer class="site-footer">
    <div class="footer-grid">
      <div class="footer-box">
        <h3>Kontakt</h3>
        <p>
          <img class="icon" src="/assets/img/icon-lokalizacja.png" alt="" />
          Stowarzyszenie Apostolstwo Miłosiedzia Hospicjum Domowe pod wezwaniem św. Alojzego Orione<br/>
          ul. Gdańska 4, 01-633 Warszawa<br>
        </p>
        <p>
          <img class="icon" src="/assets/img/icon-telefon.png" alt="" />
          +48 22 897 68 33
        </p>
        <p>
          <img class="icon" src="/assets/img/icon-mail.png" alt="" />
          …@…
        </p>
      </div>

      <div class="footer-box">
        <h3>Wpłaty / Darowizny</h3>
        <p>
          <img class="icon" src="/assets/img/icon-monety.png" alt="" />
          Nr konta: PL 42 1090 1030 0000 0001 1546 1359
        </p>
        <p>
          <img class="icon" src="/assets/img/icon-krs.png" alt="" />
          Przekaż 1,5% podatku - KRS: 0000332316
        </p>
        <p>
          <a href="#wplaty" data-page="wplaty" class="navlink">Wszystkie formy płatności</a>
        </p>
      </div>
    </div>

    <div class="footer-small">
      © <span id="year"></span> Stowarzyszenie Apostolstwo Miłosierdzia Hospicjum Domowe pw. św. Alojzego Orione
    </div>
  </footer>

  <script src="/assets/js/app.js"></script>
  <script src="/assets/js/loadnews.js"></script>
  <script src="/assets/js/qr.js"></script>
